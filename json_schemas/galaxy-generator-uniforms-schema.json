                                    "is_existence_known_to_all": {
                                        "type": "boolean"
                                    },
                                    "is_primary_fixture_player_home_planet": {
                                        "type": "boolean"
                                    },
                                    "override_militia_supply": {
                                        "type": "string"
                                    },
                                    "primary_random_fixture_filling_name": {
                                        "type": "string"
                                    },
                                    "primary_random_fixture_with_moon_filling_name": {
                                        "type": "string"
                                    },
                                    "secondary_random_fixture_filling_name": {
                                        "type": "string"
                                    }
                                },
                                "unevaluatedProperties": false
                            },
                            "name": {
                                "type": "string"
                            }
                        },
                        "unevaluatedProperties": false
                    }
                },
                "npc_fillings": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "filling": {
                                "type": "object",
                                "properties": {
                                    "npc_filling_type": {
                                        "type": "string",
                                        "enum": [
                                            "militia",
                                            "guardian",
                                            "enemy_faction",
                                            "friendly_faction"
