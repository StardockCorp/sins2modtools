                                                    "type": "string"
                                                },
                                                "ignore_orbit_overlap_checks": {
                                                    "type": "boolean"
                                                },
                                                "inherit_original_parent_orbit_direction": {
                                                    "type": "boolean"
                                                },
                                                "orbit_parent": {
                                                    "type": "boolean"
                                                },
                                                "orbit_speed_scalar": {
                                                    "type": "number"
                                                },
                                                "planet_offset": {
                                                    "$ref": "#/$defs/float_range"
                                                },
                                                "sync_orbit_to_parent": {
                                                    "type": "boolean"
                                                },
                                                "use_parent_ownership": {
                                                    "type": "boolean"
                                                }
