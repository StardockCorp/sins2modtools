                    "type": "boolean"
                },
                "overwrite_moon_fillings": {
                    "type": "boolean"
                },
                "overwrite_node_fillings": {
                    "type": "boolean"
                },
                "overwrite_npc_fillings": {
                    "type": "boolean"
                },
                "overwrite_random_fixture_fillings": {
                    "type": "boolean"
                },
                "overwrite_random_gravity_well_fillings": {
                    "type": "boolean"
                },
                "overwrite_random_skybox_fillings": {
                    "type": "boolean"
                },
                "overwrite_wormhole_fillings": {
                    "type": "boolean"
                },
                "random_fixture_fillings": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "filling": {
                                "type": "object",
                                "properties": {
                                    "items": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "properties": {
                                                "name": {
                                                    "type": "string"
                                                },
                                                "probability": {
                                                    "type": "number"
                                                }
                                            },
                                            "unevaluatedProperties": false
                                        }
                                    }
                                },
                                "unevaluatedProperties": false
                            },
                            "name": {
                                "type": "string"
                            }
                        },
                        "unevaluatedProperties": false
                    }
