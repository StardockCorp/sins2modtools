                                            "unevaluatedProperties": false
                                        }
                                    }
                                },
                                "unevaluatedProperties": false
                            },
                            "name": {
                                "type": "string"
                            }
                        },
                        "unevaluatedProperties": false
                    }
                },
                "node_fillings": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "filling": {
                                "type": "object",
                                "properties": {
                                    "display_name": {
                                        "type": "string"
                                    },
                                    "editor_color": {
                                        "type": "string"
                                    },
                                    "editor_visual_tag": {
                                        "type": "string"
                                    },
                                    "gravity_wells": {
                                        "type": "string"
