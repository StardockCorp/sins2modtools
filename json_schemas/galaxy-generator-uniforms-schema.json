{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Galaxy Generator Uniforms",
    "description": "",
    "type": "object",
    "properties": {
        "ancient_starbase_id": {
            "type": "string"
        },
        "base_fillings": {
            "$ref": "#/$defs/galaxy_chart_fillings"
        },
        "capturable_units": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "combined_fillings": {
            "$ref": "#/$defs/galaxy_chart_fillings"
        },
        "gravity_well_orbit_durations_by_hierarchy_depth": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/gravity_well_orbit_duration_min_max"
            }
        },
        "gravity_well_y_offsets_by_hierarchy_depth": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/float_range"
            }
        },
        "max_ancient_starbases": {
            "type": "integer"
        },
        "max_capturable_units": {
            "type": "integer"
        },
        "min_jumps_to_any_home_planet_for_loot_level": {
            "type": "array",
            "items": {
                "type": "integer"
            }
        },
        "minimum_gravity_well_distances_by_hierarchy_depth": {
            "type": "array",
            "items": {
                "type": "number"
            }
        },
        "player_phase_resonance_points": {
            "type": "array",
            "items": {
                "type": "integer"
            }
        },
        "secondary_fixture_y_offset": {
            "$ref": "#/$defs/float_range"
        },
        "version": {
            "type": "integer"
        }
    },
    "unevaluatedProperties": false,
    "$defs": {
        "ability_definition_ptr": {
            "type": "string"
        },
        "gravity_well_filling_socket": {
            "type": "object",
            "properties": {
                "angle": {
                    "$ref": "#/$defs/float_range"
                },
                "distance_as_percent_of_parent_inner_move_radius": {
                    "$ref": "#/$defs/float_range"
                },
                "socket_children": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/gravity_well_filling_socket"
                    }
                }
            },
            "unevaluatedProperties": false
        },
        "gravity_well_orbit_duration": {
            "type": "object",
            "properties": {
                "radius": {
                    "type": "number"
                },
                "time_in_hours": {
                    "type": "number"
                }
            },
            "unevaluatedProperties": false
        },
        "unit_definition_ptr": {
            "type": "string"
        },
        "unit_item_definition_ptr": {
            "type": "string"
        },
        "float_range": {
            "type": "array",
            "items": {
                "type": "number"
            },
            "maxItems": 2
        },
        "gravity_well_orbit_duration_min_max": {
            "type": "object",
            "properties": {
                "max": {
                    "$ref": "#/$defs/gravity_well_orbit_duration"
                },
                "min": {
                    "$ref": "#/$defs/gravity_well_orbit_duration"
                }
            },
            "unevaluatedProperties": false
        },
        "galaxy_chart_fillings": {
            "type": "object",
            "properties": {
                "artifacts": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "fixture_fillings": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "filling": {
                                "type": "object",
                                "properties": {
                                    "crystal_asteroid_extractor": {
                                        "description": "extractor unit spawned on crystal asteroids when gravity well has no planet fixtures",
                                        "type": "string"
                                    },
                                    "entity_definition": {
                                        "type": "string"
                                    },
                                    "max_capturable_units": {
                                        "description": "max capturable units (e.g. extractors) spawned per gravity well with this fixture type. 0 = no limit",
                                        "type": "integer"
                                    },
                                    "metal_asteroid_extractor": {
                                        "description": "extractor unit spawned on metal asteroids when gravity well has no planet fixtures",
                                        "type": "string"
                                    },
                                    "militia_supply": {
                                        "type": "array",
                                        "items": {
                                            "type": "integer"
                                        },
                                        "minItems": 2,
                                        "maxItems": 2
                                    },
                                    "neutral_unit_spawn_chance": {
                                        "description": "probability (0 to 1) of spawning neutral units in a gravity well with this fixture type",
                                        "type": "number"
                                    },
                                    "random_crystal_asteroids": {
                                        "description": "crystal asteroids spawned when gravity well has no planet fixtures",
                                        "type": "object",
                                        "properties": {
                                            "tiers": {
                                                "type": "array",
                                                "items": {
                                                    "type": "object",
                                                    "properties": {
                                                        "count": {
                                                            "description": "how many asteroids?",
                                                            "type": "array",
                                                            "items": {
                                                                "type": "integer"
                                                            },
                                                            "minItems": 2,
                                                            "maxItems": 2
                                                        },
                                                        "tier": {
                                                            "description": "binding to specific asteroid type in planet.uniforms",
                                                            "type": "integer"
                                                        }
                                                    },
                                                    "unevaluatedProperties": false
                                                }
                                            }
                                        },
                                        "unevaluatedProperties": false
                                    },
                                    "random_metal_asteroids": {
                                        "description": "metal asteroids spawned when gravity well has no planet fixtures",
                                        "type": "object",
                                        "properties": {
                                            "tiers": {
                                                "type": "array",
                                                "items": {
                                                    "type": "object",
                                                    "properties": {
                                                        "count": {
                                                            "description": "how many asteroids?",
                                                            "type": "array",
                                                            "items": {
                                                                "type": "integer"
                                                            },
                                                            "minItems": 2,
                                                            "maxItems": 2
                                                        },
                                                        "tier": {
                                                            "description": "binding to specific asteroid type in planet.uniforms",
                                                            "type": "integer"
                                                        }
                                                    },
                                                    "unevaluatedProperties": false
                                                }
                                            }
                                        },
                                        "unevaluatedProperties": false
                                    },
                                    "required_planet_bonuses": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        }
                                    },
                                    "spawn_unit_buff": {
                                        "description": "buff applied to units spawned via spawn_unit_definitions",
                                        "type": "string"
                                    },
                                    "spawn_unit_buff_data_source": {
                                        "description": "action data source for spawn_unit_buff",
                                        "type": "string"
                                    },
                                    "spawn_unit_definitions": {
                                        "description": "unowned units spawned in gravity wells with this fixture type when neutral_unit_spawn_chance succeeds",
                                        "type": "object",
                                        "properties": {
                                            "formation_type": {
                                                "$ref": "#/$defs/formation_type"
                                            },
                                            "random_units": {
                                                "type": "array",
                                                "items": {
                                                    "type": "object",
                                                    "properties": {
                                                        "options": {
                                                            "type": "object",
                                                            "properties": {
                                                                "forced_leveled_up_abilities": {
                                                                    "type": "array",
                                                                    "items": {
                                                                        "$ref": "#/$defs/ability_definition_ptr"
                                                                    }
                                                                },
                                                                "forced_strikecraft_index": {
                                                                    "type": "integer"
                                                                },
                                                                "is_temporary_ruler_ship": {
                                                                    "type": "boolean"
                                                                },
                                                                "items": {
                                                                    "type": "array",
                                                                    "items": {
                                                                        "$ref": "#/$defs/unit_item_definition_ptr"
                                                                    }
                                                                },
                                                                "level": {
                                                                    "type": "integer"
                                                                }
                                                            },
                                                            "unevaluatedProperties": false
                                                        },
                                                        "unit": {
                                                            "$ref": "#/$defs/unit_definition_ptr"
                                                        },
                                                        "weight": {
                                                            "type": "number"
                                                        }
                                                    },
                                                    "required": [
                                                        "unit",
                                                        "weight"
                                                    ],
                                                    "unevaluatedProperties": false
                                                }
                                            },
                                            "required_units": {
                                                "type": "array",
                                                "items": {
                                                    "type": "object",
                                                    "properties": {
                                                        "count": {
                                                            "type": "array",
                                                            "items": {
                                                                "type": "integer"
                                                            },
                                                            "minItems": 2,
                                                            "maxItems": 2
                                                        },
                                                        "options": {
                                                            "type": "object",
                                                            "properties": {
                                                                "forced_leveled_up_abilities": {
                                                                    "type": "array",
                                                                    "items": {
                                                                        "$ref": "#/$defs/ability_definition_ptr"
                                                                    }
                                                                },
                                                                "forced_strikecraft_index": {
                                                                    "type": "integer"
                                                                },
                                                                "is_temporary_ruler_ship": {
                                                                    "type": "boolean"
                                                                },
                                                                "items": {
                                                                    "type": "array",
                                                                    "items": {
                                                                        "$ref": "#/$defs/unit_item_definition_ptr"
                                                                    }
                                                                },
                                                                "level": {
                                                                    "type": "integer"
                                                                }
                                                            },
                                                            "unevaluatedProperties": false
                                                        },
                                                        "unit": {
                                                            "$ref": "#/$defs/unit_definition_ptr"
                                                        }
                                                    },
                                                    "required": [
                                                        "unit"
                                                    ],
                                                    "unevaluatedProperties": false
                                                }
                                            }
                                        },
                                        "unevaluatedProperties": false
                                    }
                                },
                                "unevaluatedProperties": false
                            },
                            "name": {
                                "type": "string"
                            }
                        },
                        "unevaluatedProperties": false
                    }
                },
                "gravity_well_fillings": {
                    "type": "array",
